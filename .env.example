# Spark8Edge Environment Variables
# Copy this file to .env.local and fill in the values for local development
# For production, set these in Vercel Dashboard > Settings > Environment Variables

# ============================================================================
# SITE CONFIGURATION
# ============================================================================

# Site URL (required for sitemap and canonical URLs)
SITE_URL=https://www.spark8edge.co.ke
NEXT_PUBLIC_SITE_URL=https://www.spark8edge.co.ke

# API Configuration
NEXT_PUBLIC_API_URL=https://www.spark8edge.co.ke/api

# ============================================================================
# CLOUDFLARE TURNSTILE (Anti-bot protection)
# ============================================================================

# Required for form spam protection on all contact forms
# Get from: https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# ============================================================================
# EMAIL CONFIGURATION (optional - currently logs to console)
# ============================================================================

# Contact email for inquiries
CONTACT_EMAIL=info@spark8edge.co.ke

# Resend.com email service (uncomment to enable actual email sending)
# RESEND_API_KEY=your_resend_api_key_here

# Email addresses for different form types
# EMAIL_FROM=info@spark8edge.co.ke
# EMAIL_TO_YOUTH=youth@spark8edge.co.ke
# EMAIL_TO_CORPORATE=corporate@spark8edge.co.ke
# EMAIL_TO_SUBSCRIBE=subscribe@spark8edge.co.ke

# Alternative email service providers (uncomment as needed)
# SENDGRID_API_KEY=your_sendgrid_api_key_here
# MAILGUN_API_KEY=your_mailgun_api_key_here
# MAILGUN_DOMAIN=your_mailgun_domain_here

# ============================================================================
# ANALYTICS & MONITORING
# ============================================================================

# Next.js Bundle Analyzer (set to 'true' to enable during build)
ANALYZE=

# Vercel Analytics (auto-provided by Vercel deployment)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID is set automatically by Vercel

# ============================================================================
# DEVELOPMENT & DEBUGGING
# ============================================================================

# Node environment
NODE_ENV=development

# Vercel platform detection (auto-set by Vercel)
# VERCEL=1

# Orchid environment detection (if using Orchid deployment)
# ORCHID_ENV=

# ============================================================================
# RATE LIMITING & PERFORMANCE (Production Recommendations)
# ============================================================================

# For production deployments, consider implementing rate limiting to prevent abuse
# Recommended configurations for Vercel Edge Functions/API routes:

# Rate limiting via Vercel KV (Redis) or Upstash Redis:
# UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_redis_token

# Vercel KV database for rate limiting (recommended for Edge runtime)
# KV_REST_API_URL=https://your-kv-url.vercel-storage.com
# KV_REST_API_TOKEN=your_kv_token

# Rate limiting configuration (suggested values):
# - Contact forms: 5 requests per IP per 15 minutes
# - Newsletter signups: 3 requests per IP per hour  
# - General API: 100 requests per IP per day

# ============================================================================
# SECURITY NOTES
# ============================================================================

# 1. NEVER commit .env.local or any file containing real secrets to git
# 2. Use Vercel Dashboard for production environment variables
# 3. Rotate secrets regularly and audit access
# 4. Use different keys for development and production environments
# 5. Implement rate limiting for public API endpoints to prevent abuse
